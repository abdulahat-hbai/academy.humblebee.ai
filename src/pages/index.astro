---
import Navbar from "@/components/layout/Navbar.astro";
import Hero from "@/components/sections/Hero.astro";
import Layout from "@/layouts/Main.astro";
import WhyChoose from "@/components/sections/WhyChoose.astro";
import WhoisFor from "@/components/sections/WhoisFor.astro";
import TalentRoadmap from "@/components/sections/TalentRoadmap.astro";
import OurMentors from "@/components/sections/OurMentors.astro";
import Testimonials from "@/components/sections/Testimonials.astro";
import AboutSection from "@/components/sections/AboutSection.astro";
import FAQ from "@/components/sections/FAQ.astro";
import StayInLoop from "@/components/sections/StayInLoop.astro";
import Footer from "@/components/layout/Footer.astro";
---

<Layout>
	<Navbar />
	<Hero />
	<WhyChoose />
	<TalentRoadmap />
	<WhoisFor />
	<Testimonials />
	<AboutSection />
	<OurMentors />
	<FAQ />
	<StayInLoop />
	<Footer />
</Layout>

