---
import Container from "./Container.astro";

const programs = [
  { label: "Engineering Fundamentals", href: "#" },
  { label: "Soft landing", href: "#" },
  { label: "Foundation", href: "#" },
  { label: "Growth-3", href: "#" },
  { label: "Free curriculum", href: "#" },
  { label: "Scholarship", href: "#" },
];

const company = [
  { label: "About us", href: "#" },
  { label: "Vision", href: "#" },
  { label: "Testimonials", href: "#" },
  { label: "FAQ", href: "#" },
];

const contacts = [
  {
    icon: "mail",
    label: "contact@humblebee.ai",
    href: "mailto:contact@humblebee.ai",
  },
  { icon: "telegram", label: "Chat on Telegram", href: "#" },
  { icon: "bot", label: "Chat with AI chatbot", href: "#" },
  { icon: "location", label: "Incheon, South Korea", href: "#" },
  { icon: "location", label: "Tashkent, Uzbekistan", href: "#" },
  { icon: "location", label: "Namangan, Uzbekistan", href: "#" },
];

const currentYear = new Date().getFullYear();
---

<footer>
  <!-- ============================================= -->
  <!-- SECTION 1: CTA AREA (dotted background here) -->
  <!-- ============================================= -->
  <section class="cta-section relative w-full overflow-hidden">
    <!-- Layer 1: Dotted yellow background image -->
    <div class="absolute inset-0 cta-bg"></div>

    <!-- Layer 2: Dark gradient overlay for text readability -->
    <div class="absolute inset-0 cta-gradient"></div>

    <!-- Layer 3: Bottom fade into dark footer -->
    <div
      class="absolute bottom-0 left-0 right-0 h-100 bg-gradient-to-b from-transparent to-[#0a0a0a]"
    >
    </div>

    <!-- Layer 4: CTA Content -->
    <div class="relative z-10 w-full cta-content-bg py-20">
      <div class="flex flex-col items-center text-center max-w-2xl mx-auto">
        <p
          class="text-[13px] tracking-[0.3em] font-medium text-white/60 uppercase mb-6"
        >
          /JOIN THE HIVE
        </p>

        <h2
          class="text-4xl md:text-5xl lg:text-[56px] leading-[1.1] font-heading font-medium tracking-tight text-white mb-8"
        >
          Ready to master tomorrow's top skill?
        </h2>

        <p
          class="text-[15px] text-white/70 font-sans leading-[1.7] mb-12 max-w-xl"
        >
          According to the World Economic Forum's Future of Jobs Report 2025, AI
          and big data skills are the fastest-growing globally, with networks
          and cybersecurity ranked #2.
        </p>

        <a
          href="#"
          class="flex items-stretch group cursor-pointer no-underline"
        >
          <div
            class="bg-white px-8 py-4 text-black font-semibold text-[14px] group-hover:bg-white/90 transition-colors"
          >
            Join the hive
          </div>
          <div
            class="bg-white border-l border-black/10 px-4 flex items-center group-hover:bg-white/90 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- SECTION 2: FOOTER CONTENT (solid dark bg)    -->
  <!-- ============================================= -->
  <section class="footer-content bg-[#0a0a0a]">
    <Container>
      <div class="py-16 lg:py-20">
        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8"
        >
          <!-- Column 1: Logo + Social Icons -->
          <div class="lg:col-span-3 flex flex-col gap-8">
            <!-- Yellow Logo -->
            <a href="/" class="flex items-center no-underline">
              <img
                src="/images/logo.svg"
                alt="HumbleBeeAI Academy"
                class="h-9 w-auto"
              />
            </a>

            <!-- White Social Icons -->
            <div class="flex items-center gap-4">
              <!-- Telegram -->
              <a
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Telegram"
                class="text-white hover:text-brand transition-colors"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  ><path
                    d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
                  ></path></svg
                >
              </a>
              <!-- LinkedIn -->
              <a
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="LinkedIn"
                class="text-white hover:text-brand transition-colors"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  ><path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                  ></path></svg
                >
              </a>
              <!-- YouTube -->
              <a
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="YouTube"
                class="text-white hover:text-brand transition-colors"
              >
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  ><path
                    d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
                  ></path></svg
                >
              </a>
              <!-- Instagram -->
              <a
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram"
                class="text-white hover:text-brand transition-colors"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  ><path
                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"
                  ></path></svg
                >
              </a>
              <!-- X (Twitter) -->
              <a
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="X"
                class="text-white hover:text-brand transition-colors"
              >
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  ><path
                    d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                  ></path></svg
                >
              </a>
            </div>
          </div>

          <!-- Column 2: Programs -->
          <div class="lg:col-span-3">
            <h4
              class="text-[12px] font-bold tracking-[0.2em] text-white uppercase mb-6"
            >
              PROGRAMS
            </h4>
            <ul class="flex flex-col gap-3 list-none p-0 m-0">
              {
                programs.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class="text-[14px] text-white/70 hover:text-white transition-colors duration-300 no-underline font-medium"
                    >
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <!-- Column 3: Company -->
          <div class="lg:col-span-2">
            <h4
              class="text-[12px] font-bold tracking-[0.2em] text-white uppercase mb-6"
            >
              COMPANY
            </h4>
            <ul class="flex flex-col gap-3 list-none p-0 m-0">
              {
                company.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class="text-[14px] text-white/70 hover:text-white transition-colors duration-300 no-underline font-medium"
                    >
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <!-- Column 4: Contact -->
          <div class="lg:col-span-4">
            <h4
              class="text-[12px] font-bold tracking-[0.2em] text-white uppercase mb-6"
            >
              CONTACT
            </h4>
            <ul class="flex flex-col gap-3 list-none p-0 m-0">
              {
                contacts.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class="flex items-center gap-2.5 text-[14px] text-white/70 hover:text-white transition-colors duration-300 no-underline font-medium"
                    >
                      <span class="w-2 h-2 rounded-full bg-brand shrink-0" />
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>

      <!-- Bottom Bar -->
      <div
        class="border-t border-white/10 py-6 flex flex-col md:flex-row justify-between items-center gap-4"
      >
        <p class="text-[13px] text-white/40 font-medium">
          &copy; {currentYear} HumbleBeeAI Academy | All rights reserved
        </p>
        <div class="flex items-center gap-6">
          <a
            href="#"
            class="text-[13px] text-white/50 hover:text-white transition-colors duration-300 no-underline font-medium"
          >
            Privacy policy
          </a>
          <a
            href="#"
            class="text-[13px] text-white/50 hover:text-white transition-colors duration-300 no-underline font-medium"
          >
            Terms of service
          </a>
        </div>
      </div>
    </Container>
  </section>
</footer>

<style>
  .cta-bg {
    background-image: url("/images/footer.png");
    background-size: cover;
    background-position: center;
    background-color: #000;
  }

  /* Dark gradient overlay ABOVE image, BELOW text */
  .cta-gradient {
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.75) 0%,
      rgba(0, 0, 0, 0.55) 40%,
      rgba(0, 0, 0, 0.3) 70%,
      rgba(0, 0, 0, 0) 100%
    );
  }
</style>
