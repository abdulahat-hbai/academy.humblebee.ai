---
import Container from "../layout/Container.astro";
import SectionLine from "../ui/SectionLine.astro";

const news = [
  {
    category: "CATEGORY HERE",
    date: "02.24.2025",
    title: "What is AI – Artificial Intelligence: Is it safe, will it replace human jobs, what will future look like?",
    image: "/images/stayloop/hourglass.webp"
  },
  {
    category: "CATEGORY HERE",
    date: "02.24.2025",
    title: "What is AI – Artificial Intelligence: Is it safe, will it replace human jobs, what will future look like?",
    image: "/images/stayloop/hourglass2.webp"
  },
  {
    category: "CATEGORY HERE",
    date: "02.24.2025",
    title: "What is AI – Artificial Intelligence: Is it safe, will it replace human jobs, what will future look like?",
    image: "/images/stayloop/docker.webp"
  }
];
---

<section class="relative mt-28 bg-background">
  <SectionLine />

  <Container class="py-20 lg:py-28">
    <!-- Header Row -->
    <div class="flex items-end justify-between mb-12">
      <div>
        <p class="section-label text-foreground">
          <span class="text-subtitle">/08</span> NEWS & EVENTS
        </p>
        <h2 class="section-title">Stay in the loop</h2>
      </div>
      <a href="#" class="flex items-stretch group cursor-pointer h-fit no-underline shrink-0">
        <div class="bg-brand px-8 py-4 text-black font-bold uppercase tracking-widest text-[16px] group-hover:bg-brand-hover transition-colors">
          View all
        </div>
        <div class="bg-brand border-l border-black/10 px-4 flex items-center justify-center group-hover:bg-brand-hover transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform duration-300">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </div>
      </a>
    </div>

    <!-- News Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {news.map((post) => (
        <a href="#" class="group no-underline flex flex-col bg-white border border-border overflow-hidden hover:shadow-lg transition-shadow duration-300">
          <div class="w-full aspect-[4/3] overflow-hidden bg-zinc-100">
            <img
              src={post.image}
              alt={post.title}
              class="w-full h-full object-cover grayscale transition-all duration-500 group-hover:grayscale-0 group-hover:scale-105"
            />
          </div>
          <div class="p-5">
            <div class="flex items-center justify-between gap-4 mb-3">
              <span class="text-[16px] font-medium text-zinc-400">
                {post.category}
              </span>
              <span class="text-[16px] font-medium text-zinc-400 shrink-0">
                {post.date}
              </span>
            </div>
            <h3 class="section-subtitle text-foreground group-hover:text-foreground/70 transition-colors leading-snug line-clamp-3">
              {post.title}
            </h3>
          </div>
        </a>
      ))}
    </div>
  </Container>
</section>
