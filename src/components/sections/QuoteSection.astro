---
import Container from "@/components/layout/Container.astro";
---

<section class="flex flex-col w-full bg-[#0a0a0a] relative overflow-hidden">
  <!-- Vertical Lines Overlay (White vertical borders matching global container) -->
  <div class="absolute inset-0 z-20 pointer-events-none">
    <Container class="h-full">
      <div class="h-full border-x border-white/20"></div>
    </Container>
  </div>

  <!-- Top Image - Fixed Height 380px -->
  <div class="relative w-full h-[380px]">
    <img 
      src="/fog-mountains.webp" 
      alt="Fog Mountains" 
      class="w-full h-full object-cover grayscale brightness-75 transition-all duration-700 hover:scale-105" 
    />
    <!-- Bottom fade into the dark section -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#0a0a0a]"></div>
  </div>

  <!-- Quote/Description Area - Height 330px -->
  <div class="w-full bg-[#0a0a0a] relative z-10">
    <Container class="flex flex-col items-center justify-center text-center h-[330px] max-w-[1280px] px-6">
      <!-- Slanted Lines Indicator -->
      <div class="text-brand font-medium tracking-[0.3em] mb-6 text-[22px] italic opacity-90">
        ///
      </div>

      <p class="text-white text-[32px] font-medium leading-[1.3] max-w-[860px] font-sans antialiased">
        "Welcome, future AI innovator. You have the ambition to become a top-tier AI engineer, but the path forward can seem daunting."
      </p>
    </Container>
  </div>
</section>
