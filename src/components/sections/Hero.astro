---
import Container from "@/components/layout/Container.astro";
import SectionLine from "@/components/ui/SectionLine.astro";
---

<section class="pt-16 md:pt-24 overflow-hidden relative">
  <Container class="flex flex-col items-center ">
    <div class="relative w-full pt-8 pb-12">
      <div class="flex justify-start mb-6 lg:mb-10">
        <p class="section-label text-foreground">
          /BUILT FOR SERIOUS BUILDERS
        </p>
      </div>
      <div class="flex flex-col lg:flex-row justify-between items-center gap-12 lg:gap-8">
        <div class="lg:w-[55%]">
          <h1 class="section-title text-foreground hero-title">
            Full-time AI Academy.<br />
            Built on real work.<br />
            Proven by results.
          </h1>
        </div>
        <div class="lg:w-[40%] flex flex-col items-start gap-8">
          <p class="section-subtitle text-subtitle">
            You learn under the same global standards AI experts use for real
            work: structured weeks, mentor review, and evidence-backed outcomes
            &ndash; not just finished videos.
          </p>
          <a href="#" class="flex items-stretch group cursor-pointer h-fit no-underline">
            <div class="bg-brand px-8 py-4 text-black font-bold uppercase tracking-widest text-[16px] group-hover:bg-brand-hover transition-colors">
              Be 1% beginner
            </div>
            <div class="bg-brand border-l border-black/10 px-4 flex items-center justify-center group-hover:bg-brand-hover transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform duration-300">
                <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
              </svg>
            </div>
          </a>
        </div>
      </div>
    </div>
    <div class="relative mt-24 w-full">
      <div class="shadow-[0_32px_64px_-15px_rgba(0,0,0,0.1)] overflow-hidden">
        <img src="/images/hero.webp" class="w-full h-full object-cover" alt="Hero" />
      </div>
    </div>
  </Container>
</section>
