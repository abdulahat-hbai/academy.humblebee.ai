---
import Container from "@/components/layout/Container.astro";
import Button from "../ui/Button.astro";
import SectionLine from "../ui/SectionLine.astro";
---

<section class="pt-16 md:pt-24 overflow-hidden relative">
  <Container class="flex flex-col items-center">
    <div class="relative w-full pt-8 pb-12">
      <div class="flex justify-start mb-6 lg:mb-10">
        <p
          class="text-sm tracking-widest font-medium text-foreground uppercase"
        >
          /BUILT FOR SERIOUS BUILDERS
        </p>
      </div>
      <div
        class="flex flex-col lg:flex-row justify-between items-center gap-12 lg:gap-8"
      >
        <div class="lg:w-[55%]">
          <h1
            class="text-4xl md:text-[56px] lg:text-[64px] leading-[1.1] font-heading font-medium tracking-tight text-foreground"
          >
            Full-time AI Academy.<br />
            Built on real work.<br />
            Proven by results.
          </h1>
        </div>
        <div class="lg:w-[40%] flex flex-col items-start gap-8">
          <p
            class="text-[17px] text-subtitle font-medium font-sans leading-[1.6]"
          >
            You learn under the same global standards AI experts use for real
            work: structured weeks, mentor review, and evidence-backed outcomes
            &ndash; not just finished videos.
          </p>
          <Button
            variant="more"
            className="p-0 rounded-none h-auto flex items-stretch hover:bg-brand-hover transition-colors"
          >
            <span class="px-6 py-4 font-semibold text-[15px]"
              >Be 1% beginner</span
            >
            <span
              class="px-4 py-4 border-l border-background flex items-center justify-center"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
              >
            </span>
          </Button>
        </div>
      </div>
    </div>
    <div class="relative mt-24 w-full">
      <div class="shadow-[0_32px_64px_-15px_rgba(0,0,0,0.1)] overflow-hidden">
        <img src="/images/hero.webp" class="w-full h-full object-cover" />
      </div>
    </div>
  </Container>
</section>
