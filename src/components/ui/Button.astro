---
import { cn } from "@/lib/utils";

interface Props {
  variant?: "default" | "destructive" | "outline" | "secondary" | "ghost" | "link" | "more";
  size?: "default" | "xs" | "sm" | "lg" | "icon";
  class?: string;
  [key: string]: any;
}

const { variant = "default", size = "default", class: className, ...rest } = Astro.props;

const variantClasses: Record<string, string> = {
  default: "bg-primary text-primary-foreground hover:bg-primary/90",
  destructive: "bg-destructive text-white hover:bg-destructive/90",
  outline: "border bg-background shadow-xs hover:bg-accent hover:text-accent-foreground",
  secondary: "bg-secondary text-secondary-foreground hover:bg-secondary/80",
  ghost: "hover:bg-accent hover:text-accent-foreground",
  link: "text-primary underline-offset-4 hover:underline",
  more: "py-2 px-4 bg-brand text-brand-foreground font-semibold hover:bg-brand-hover",
};

const sizeClasses: Record<string, string> = {
  default: "h-9 px-4 py-4",
  xs: "h-6 gap-1 rounded-md px-2 text-xs",
  sm: "h-8 rounded-md gap-1.5 px-3",
  lg: "h-10 rounded-md px-6",
  icon: "size-9",
};

const base = "inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-medium transition-all disabled:pointer-events-none disabled:opacity-50 shrink-0 outline-none";

const classes = cn(base, variantClasses[variant], sizeClasses[size], className);
---

<button class={classes} {...rest}>
  <slot />
</button>
