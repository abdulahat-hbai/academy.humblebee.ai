---
import { roadmap } from "../../data/roadmapdata";
---

<div class="grid lg:grid-cols-2 bg-black w-full overflow-hidden min-h-[850px]" id="roadmap-interactive">

  <!-- LEFT COLUMN (Black) -->
  <div class="flex flex-col bg-black border-r border-white/5 relative overflow-hidden">
    <div class="w-full h-full flex flex-col items-end">
      <!-- Container-aligned inner box (Left side = half container) -->
      <div class="w-full max-w-195 pl-4 pr-8 lg:pr-12 h-full flex flex-col pt-20 lg:pt-28 pb-20 lg:pb-28">
        <!-- Top Text Content -->
        <div class="mb-16">
          <p class="text-[13px] tracking-[0.3em] font-medium text-white/40 uppercase mb-6 flex items-center gap-1.5">
            <span class="font-bold">/02</span> ROADMAP
          </p>
          <h2 class="text-5xl md:text-6xl lg:text-[72px] leading-[1] font-heading font-medium tracking-tighter text-white mb-8">
            Talent roadmap
          </h2>
          <p class="text-[17px] text-zinc-400 font-medium font-sans leading-[1.7] max-w-xl">
            HumbleBeeAI Academy is a full-time, offline program (40 hours/week) designed to turn committed learners into market-standard engineers. Progress is earned through shipped work, mentor review, documentation, and consistent execution over time - not by "finishing lessons".
          </p>
        </div>

        <!-- Interactive Tabs List -->
        <div class="flex flex-col border-t border-white/10 mt-auto">
          {roadmap.map((item, index) => (
            <button
              type="button"
              data-roadmap-tab={index}
              class:list={[
                "group py-8 px-8 border-b border-white/10 cursor-pointer transition-all duration-500 flex items-center gap-6 text-left relative overflow-hidden",
                index === 0 ? "text-white" : "text-zinc-600 hover:bg-white/[0.02]"
              ]}
            >
              <!-- Active Indicator Light (left edge) -->
              <div 
                class:list={[
                  "absolute left-0 top-0 bottom-0 w-[4px] bg-brand transition-transform duration-500 origin-top",
                  index === 0 ? "scale-y-100" : "scale-y-0"
                ]}
              />

              <!-- Icon (Custom square block) -->
              <div class="w-6 h-6 flex justify-center items-center shrink-0">
                <div
                  class:list={[
                    "w-5 h-5 transition-all duration-500",
                    index === 0 ? "bg-brand scale-110" : "bg-zinc-700 group-hover:bg-zinc-500"
                  ]}
                  style="mask-image: url(/iconwhy.png); -webkit-mask-image: url(/iconwhy.png); mask-size: contain; -webkit-mask-size: contain; mask-repeat: no-repeat; -webkit-mask-repeat: no-repeat;"
                />
              </div>

              <!-- Tab Title -->
              <h4 class="text-[20px] lg:text-[22px] font-medium transition-colors duration-500">
                {item.title}
              </h4>
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT COLUMN (Grayscale/Action) -->
  <div class="relative flex flex-col bg-[#0a0a0a]">
    <div class="w-full h-full flex flex-col items-start">
      <!-- Container-aligned inner box (Right side = half container) -->
      <div class="w-full max-w-195 pr-4 flex flex-col h-full overflow-hidden">
        <!-- COMPASS IMAGE AREA WITH HALFTONE EFFECT -->
        <div class="w-full aspect-[4/3] lg:h-[550px] relative overflow-hidden bg-black border-b border-white/5">
          <img
            src="/images/compass.webp"
            alt="Compass"
            class="w-full h-full object-cover grayscale brightness-125 contrast-125 object-center scale-110"
          />
          
          <!-- Halftone Dot Overlay (Senior Look) -->
          <div class="absolute inset-0 opacity-[0.15] mix-blend-multiply pointer-events-none halftone-dots"></div>
        </div>

        <!-- TAB PANEL CONTENT BOX -->
        <div class="pl-8 lg:pl-12 pr-4 pt-16 pb-12 lg:pt-28 lg:pb-20 bg-[#0c0c0c] flex-1 flex flex-col justify-center overflow-hidden">
          {roadmap.map((item, index) => (
            <div data-roadmap-panel={index} class:list={[index === 0 ? "opacity-100 translate-y-0" : "hidden opacity-0 translate-y-4", "transition-all duration-700"]}>
              
              <!-- Panel Header -->
              <div class="mb-10">
                <p class="text-[15px] font-bold text-zinc-600 mb-4 tracking-[0.2em]">{`/0${index + 1}`}</p>
                <div class="w-16 h-[2.5px] bg-brand" />
              </div>

              <!-- Panel Description (Dynamic) -->
              <div class="text-[18px] lg:text-[20px] text-zinc-300 leading-[1.7] mb-12 font-sans font-medium">
                {Array.isArray(item.description)
                  ? item.description.map((desc) => <p class="mb-4 last:mb-0">{desc}</p>)
                  : <p>{item.description}</p>
                }
              </div>

              <!-- Button (Figma Style) -->
              <button class="flex items-stretch group cursor-pointer w-fit h-fit">
                <div class="bg-brand px-10 py-5 text-black font-bold uppercase tracking-widest text-[14px] group-hover:bg-brand-hover transition-colors">
                  Learn more
                </div>
                <div class="bg-brand border-l border-black/10 px-5 flex items-center justify-center group-hover:bg-brand-hover transition-colors">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform">
                    <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                  </svg>
                </div>
              </button>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <style>
    /* Senior Halftone Dot Pattern */
    .halftone-dots {
      background-image: radial-gradient(circle, #fff 1px, transparent 1px);
      background-size: 3px 3px;
    }

    /* Animation specifically for panel transitions */
    [data-roadmap-panel]:not(.hidden) {
      display: block;
      animation: slideUpFade 0.7s cubic-bezier(0.23, 1, 0.32, 1) forwards;
    }

    @keyframes slideUpFade {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</div>

<script>
  function initRoadmap() {
    const container = document.getElementById("roadmap-interactive");
    if (!container) return;

    const tabs = container.querySelectorAll<HTMLButtonElement>("[data-roadmap-tab]");
    const panels = container.querySelectorAll<HTMLDivElement>("[data-roadmap-panel]");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const index = tab.dataset.roadmapTab!;

        // Update Tab Visuals
        tabs.forEach((t) => {
          const isActive = t.dataset.roadmapTab === index;
          t.classList.toggle("text-white", isActive);
          t.classList.toggle("text-zinc-600", !isActive);
          
          const indicator = t.querySelector('.absolute.left-0');
          if (indicator) {
            indicator.classList.toggle("scale-y-100", isActive);
            indicator.classList.toggle("scale-y-0", !isActive);
          }

          const icon = t.querySelector<HTMLDivElement>(".w-5");
          if (icon) {
            icon.classList.toggle("bg-brand", isActive);
            icon.classList.toggle("scale-110", isActive);
            icon.classList.toggle("bg-zinc-700", !isActive);
          }
        });

        // Update Panels with transition
        panels.forEach((p) => {
          if (p.dataset.roadmapPanel === index) {
            p.classList.remove("hidden");
          } else {
            p.classList.add("hidden");
          }
        });
      });
    });
  }

  initRoadmap();
  document.addEventListener("astro:after-swap", initRoadmap);
</script>
