---
const { title, img, description } = Astro.props;
---

<div class="flex flex-col gap-4">
  <div
    class="w-full overflow-hidden bg-feature-card flex items-center justify-center"
  >
    {img && <img src={img} alt={title} class="w-full h-full object-cover" />}
  </div>
  <div class="flex flex-col gap-2 mt-1">
    <h3
      class="text-[19px] font-semibold font-heading text-foreground leading-tight pr-4"
    >
      {title}
    </h3>
    <p
      class="text-[15px] text-subtitle font-medium font-sans leading-[1.4] pr-2"
    >
      {description}
    </p>
  </div>
</div>
